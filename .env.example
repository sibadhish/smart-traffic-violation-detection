# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/traffic_violations
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/traffic_violations

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Storage mode: "local" (default, no external deps) or "minio"
STORAGE_MODE=local

# MinIO (only needed if STORAGE_MODE=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_CLIPS=violation-clips
MINIO_BUCKET_EVIDENCE=evidence-packages

# ML
DETECTION_CONFIDENCE_THRESHOLD=0.5
HELMET_CONFIDENCE_THRESHOLD=0.4

# Video processing
FRAME_SKIP=3
CLIP_SECONDS_BEFORE=3
CLIP_SECONDS_AFTER=3
MIN_VIOLATION_FRAMES=5

# Security
SECRET_KEY=change-me-in-production
DEBUG=false
